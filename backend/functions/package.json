{
  "name": "fraudguard-functions",
  "description": "Firebase Cloud Functions backend for FraudGuard fraud detection APIs.",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "serve": "firebase emulators:start --only functions,firestore,auth",
    "shell": "firebase functions:shell",
